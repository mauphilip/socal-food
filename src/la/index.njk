---
title: Los Angeles
city: la
---
{% extends "base.njk" %}

{% block content %}

<div class="city-hero">
  <div style="max-width:1120px;margin:0 auto;">
    <div class="city-hero-label">City Guide</div>
    <h1 class="city-hero-title">Los Angeles</h1>
    <p class="city-hero-sub">Guides, top lists, and weekly picks from across LA.</p>
  </div>
</div>

<div class="home-section">
  <div class="home-section-header">
    <div class="home-section-title">Guides</div>
  </div>
  {% if collections.la_guides.length %}
  <div class="content-grid">
    {% for post in collections.la_guides %}
    <a class="content-card" href="{{ post.url }}">
      {% if post.data.hero %}<img class="content-card-img" src="{{ post.data.hero }}" alt="{{ post.data.title }}">{% endif %}
      <div class="content-card-body">
        <div class="content-card-eyebrow">Guide · {{ post.date | readableDate }}</div>
        <div class="content-card-title">{{ post.data.title }}</div>
        {% if post.data.lede %}<div class="content-card-lede">{{ post.data.lede }}</div>{% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <p style="color:var(--text-muted);font-size:.9rem;padding:.5rem 0;">No guides yet — check back soon.</p>
  {% endif %}
</div>

<div class="home-section">
  <div class="home-section-header">
    <div class="home-section-title">Posts</div>
  </div>
  {% if collections.la_posts.length %}
  <div class="content-grid">
    {% for post in collections.la_posts %}
    <a class="content-card" href="{{ post.url }}">
      {% if post.data.hero %}<img class="content-card-img" src="{{ post.data.hero }}" alt="{{ post.data.title }}">{% endif %}
      <div class="content-card-body">
        <div class="content-card-eyebrow">{{ post.date | readableDate }}</div>
        <div class="content-card-title">{{ post.data.title }}</div>
        {% if post.data.lede %}<div class="content-card-lede">{{ post.data.lede }}</div>{% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <p style="color:var(--text-muted);font-size:.9rem;padding:.5rem 0;">No posts yet.</p>
  {% endif %}
</div>

{% endblock %}
